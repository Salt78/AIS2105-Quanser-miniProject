<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="myfirst">
  <link name="world"/>
  <link name="base_link"/>

  <joint name="base_joint" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
  </joint>

  <xacro:include filename="$(find qube_description)/urdf/qube.macro.xacro"/>
  <xacro:qube parent="base_link" prefix="motor1_"/>
</robot>